{
  "name": "realitycheck-extension",
  "displayName": "RealityCheck – AI Deepfake Detector",
  "version": "0.1.0",
  "description": "Verify if images and videos on social media are real or AI-generated.",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.7.2",
    "plasmo": "^0.89.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0"
  },
  "manifest": {
    "host_permissions": [
      "https://twitter.com/*",
      "https://x.com/*",
      "https://*.twimg.com/*"
    ],
    "permissions": [
      "activeTab"
    ]
  }
}
